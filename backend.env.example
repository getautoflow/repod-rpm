# =============================================================================
# backend.env.example — Secrets et configuration du backend FastAPI (RPM)
# =============================================================================
# Copier ce fichier en backend.env et adapter :
#   cp backend.env.example backend.env
# Ne JAMAIS committer le backend.env réel (déjà dans .gitignore).
#
# IMPORTANT : Docker Compose effectue une substitution de variables dans les
# fichiers env_file. Les `$` littéraux (ex : hash bcrypt) doivent être
# échappés en `$$`.
# =============================================================================

# -----------------------------------------------------------------------------
# JWT — Authentification
# -----------------------------------------------------------------------------
# Clé secrète de signature des tokens. Générer avec :
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_HEX_STRING

# Durée de vie des tokens en minutes (défaut : 60)
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Compte administrateur initial
# Créé automatiquement au premier démarrage si la base users.db est vide.
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin

# Hash bcrypt du mot de passe admin. Générer avec :
#   python3 -c "from passlib.hash import bcrypt; print(bcrypt.hash('votre_mot_de_passe'))"
# Remplacer ensuite chaque `$` par `$$` dans la valeur ci-dessous.
# Valeur ci-dessous = hash de "changeme" — À CHANGER EN PRODUCTION.
ADMIN_PASSWORD_HASH=$$2b$$12$$jYP5m7IkXWxOrjm/fPdM.eVZl8mkGBuAFVdEBNPaC0Z4/2.WQHWyW

# -----------------------------------------------------------------------------
# CORS — Origines autorisées (séparées par des virgules)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3003,http://localhost:8000,http://192.168.56.10:3000,http://192.168.56.10:3003,http://192.168.56.10:8000

# -----------------------------------------------------------------------------
# Rate limiting sur les endpoints d'authentification (requêtes/minute par IP)
# -----------------------------------------------------------------------------
AUTH_RATELIMIT_PER_MINUTE=10

# -----------------------------------------------------------------------------
# SSH — Host cible pour le script de téléchargement de paquets
# -----------------------------------------------------------------------------
SSH_HOST=192.168.56.1

# -----------------------------------------------------------------------------
# Chemins internes (montés via volumes Docker — ne pas modifier sauf si vous
# changez les volumes dans docker-compose.yaml)
# -----------------------------------------------------------------------------
POOL_DIR=/repos/pool
MANIFEST_DIR=/repos/manifests
STAGING_INCOMING=/repos/staging/incoming
STAGING_QUARANTINE=/repos/staging/quarantine
AUDIT_DIR=/repos/audit
INDEX_PATH=/repos/manifests/index.json
ADD_RPM_SCRIPT=/scripts/add-rpm.sh
INDEX_DIR=/repos/package-index
IMPORTS_DIR=/repos/imports
CLAMAV_DB_DIR=/var/lib/clamav
AUTH_DB_PATH=/repos/auth/users.db
SETTINGS_PATH=/repos/settings.json
GRYPE_DB_CACHE_DIR=/repos/grype-db
SECURITY_DIR=/repos/security
NGINX_LOGS_DIR=/repos/logs
GNUPG_HOME=/repos/gnupg
REPO_BASE=/repos
