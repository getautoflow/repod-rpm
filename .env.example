# =============================================================================
# .env.example — Variables docker-compose (RPM Repo Manager)
# =============================================================================
# Copier ce fichier en .env et adapter :
#   cp .env.example .env
# Ne JAMAIS committer le .env réel (déjà dans .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# URLs publiques
# En développement local (Vagrant) :
#   PUBLIC_URL=http://192.168.56.10:3000
# En production avec reverse-proxy + TLS :
#   PUBLIC_URL=https://repo.example.com
# -----------------------------------------------------------------------------
PUBLIC_URL=http://192.168.56.10:3000
REACT_APP_API_URL=http://192.168.56.10:8000
REACT_APP_REPO_URL=http://192.168.56.10:80

# -----------------------------------------------------------------------------
# Version de l'image (tag Docker)
# -----------------------------------------------------------------------------
APP_VERSION=v1.0.0

# -----------------------------------------------------------------------------
# Binding des ports
# Mode direct (dev / Vagrant) : BIND_HOST=0.0.0.0
# Mode reverse-proxy : BIND_HOST=127.0.0.1
# -----------------------------------------------------------------------------
BIND_HOST=0.0.0.0
FRONTEND_PORT=3003
BACKEND_PORT=8000
RPM_PORT=80
